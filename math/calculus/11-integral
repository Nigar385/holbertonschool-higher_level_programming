#!/usr/bin/env python3
"""Module for computing the integral of a polynomial."""


def poly_integral(poly, C=0):
    """Calculate the integral of a polynomial.

    Args:
        poly (list): list of coefficients representing a polynomial,
            where the index represents the power of x.
        C (int or float): integration constant.

    Returns:
        list: new list of coefficients representing the integral,
            or None if poly or C are invalid.
    """
    if not isinstance(poly, list) or len(poly) == 0:
        return None
    if not isinstance(C, (int, float)):
        return None
    if not all(isinstance(c, (int, float)) for c in poly):
        return None

    if poly == [0]:
        return [C]

    integral = [C]
    for i, coef in enumerate(poly):
        new_coef = coef / (i + 1)
        if new_coef == int(new_coef):
            new_coef = int(new_coef)
        integral.append(new_coef)

    return integral
